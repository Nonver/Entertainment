		flex: 1;
		font-size: 26rpx;
		color: #333333;
	}

	/* 平台切换栏 */
	.platform-bar {
		flex-direction: row;
		align-items: center;
		background-color: #FFFFFF;
		border-radius: 12rpx;
		padding: 16rpx 20rpx;
		margin: 0 24rpx 16rpx 24rpx;
	}

	.platform-logo {
		width: 56rpx;
		height: 56rpx;
		border-radius: 8rpx;
		margin-right: 14rpx;
	}

	.platform-name {
		font-size: 28rpx;
		color: #333333;
		font-weight: 500;
		flex: 1;
	}

	.switch-btn {
		background-color: #F0C275;
		border-radius: 24rpx;
		padding: 10rpx 22rpx;
	}

	.switch-text {
		font-size: 24rpx;
		color: #FFFFFF;
		font-weight: 500;
	}

	/* Tab（双行布局） */
	.tab-scroll {
		padding: 0 24rpx;
		background-color: #FFFFFF;
		border-radius: 12rpx;
		padding: 16rpx 20rpx;
		margin: 0 24rpx 16rpx 24rpx;
	}

	.tab-row {
		flex-direction: row;
		padding: 16rpx 0 0 0;
		justify-content: space-evenly;
	}

	.tab-item {
		flex-shrink: 0;
		padding: 20rpx 0 16rpx 0;
		margin-right: 36rpx;
		border-bottom-width: 4rpx;
		border-bottom-style: solid;
		border-bottom-color: transparent;
	}

	.tab-active {
		border-bottom-color: #F0C275;
	}

	.tab-text {
		font-size: 28rpx;
		color: #999999;
	}

	.tab-text-active {
		color: #333333;
		font-weight: 600;
	}

	/* 列表 */
	.list-container {
		padding: 5rpx 24rpx 30rpx 24rpx;
		height: calc(100vh - 380rpx);
	}

	.record-card {
		background-color: #FFFFFF;
		border-radius: 12rpx;
		overflow: hidden;
		margin-bottom: 16rpx;
	}

	.record-row1 {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding: 24rpx 24rpx 16rpx 24rpx;
	}

	.record-type {
		font-size: 28rpx;
		color: #333333;
		font-weight: 500;
	}

	.record-amount {
		font-size: 32rpx;
		font-weight: bold;
	}

	.amount-in {
		color: #52C41A;
	}

	.amount-out {
		color: #FF4D4F;
	}

	.record-row2 {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding: 0 24rpx 12rpx 24rpx;
	}

	.record-balance {
		font-size: 24rpx;
		color: #666666;
	}

	.record-agent {
		font-size: 24rpx;
		color: #666666;
	}

	.record-row3 {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		background-color: #F0C275;
		padding: 14rpx 24rpx;
	}

	.record-no {
		font-size: 24rpx;
		color: #333333;
	}

	.record-time {
		font-size: 24rpx;
		color: #333333;
	}

	/* 空状态 */
	.empty-state {
		padding: 120rpx 0;
		align-items: center;
	}

	.empty-icon {
		width: 160rpx;
		height: 140rpx;
		margin-bottom: 20rpx;
	}

	.empty-text {
		font-size: 28rpx;
		color: #CCCCCC;
	}

	/* 没有更多了 */
	.no-more {
		padding: 40rpx 0 60rpx 0;
		align-items: center;
	}

	.no-more-text {
		font-size: 24rpx;
		color: #CCCCCC;
	}

	/* 弹窗 */
	.popup-mask {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.5);
		z-index: 999;
		justify-content: flex-end;
	}

	.popup-content {
		background-color: #FFFFFF;
		border-radius: 24rpx 24rpx 0 0;
		max-height: 70vh;
	}

	.popup-header {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding: 28rpx 30rpx;
		border-bottom: 1rpx solid #F0EDE6;
	}

	.popup-cancel {
		font-size: 28rpx;
		color: #F0C275;
	}

	.popup-title {
		font-size: 32rpx;
		color: #333333;
		font-weight: 600;
	}

	.popup-close {
		font-size: 32rpx;
		color: #999999;
	}

	.popup-list {
		max-height: 60vh;
	}

	.popup-item {
		flex-direction: row;
		align-items: center;
		padding: 26rpx 30rpx;
		border-bottom: 1rpx solid #F5F0E8;
	}

	.popup-item-logo {
		width: 64rpx;
		height: 64rpx;
		border-radius: 12rpx;
		margin-right: 20rpx;
	}

	.popup-item-name {
		font-size: 30rpx;
		color: #333333;
	}
</style>