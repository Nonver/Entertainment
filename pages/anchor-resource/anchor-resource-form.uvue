            </view>
          </view>
        </view>

        <!-- Field 4.6: 主播流水 -->
        <view class="form-item">
          <text class="form-label">主播流水 <text class="required">*</text></text>
          <view class="upload-area" @click="chooseFlowPhoto">
            <image v-if="form.flow_photo" :src="form.flow_photo" mode="aspectFill" class="preview-img"></image>
            <view v-else class="upload-placeholder">
              <svg class="upload-icon" viewBox="0 0 24 24" fill="none" stroke="#b5ad9e" stroke-width="1.8">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
              <text class="upload-text">点击上传流水截图</text>
            </view>
          </view>
        </view>

        <!-- Field 5: 主播工会 -->
        <view class="form-item">
          <text class="form-label">主播工会</text>
          <view class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 00-3-3.87"/>
              <path d="M16 3.13a4 4 0 010 7.75"/>
            </svg>
            <input type="text" v-model="form.union_name" placeholder="请输入所属工会" placeholder-class="ph" class="form-input" />
          </view>
        </view>

        <!-- Field 6: 主播现待遇 -->
        <view class="form-item">
          <text class="form-label">主播现待遇</text>
          <view class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
            <input type="text" v-model="form.current_salary" placeholder="请输入当前待遇情况" placeholder-class="ph" class="form-input" />
          </view>
        </view>

        <!-- Field 7: 主播到期时间 -->
        <view class="form-item">
          <text class="form-label">主播到期时间 <text class="required">*</text></text>
          <view class="input-wrapper">
            <picker mode="date" :value="form.expire_date" @change="onDateChange" style="width: 100%;">
				<svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="top: 25rpx;">
				  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
				  <line x1="16" y1="2" x2="16" y2="6"/>
				  <line x1="8" y1="2" x2="8" y2="6"/>
				  <line x1="3" y1="10" x2="21" y2="10"/>
				</svg>
              <view class="picker-display">
                <text :class="form.expire_date ? 'picker-text' : 'picker-placeholder'">
                  {{ form.expire_date || '请选择到期时间' }}
                </text>
                
              </view>
            </picker>
          </view>
        </view>

        <!-- Field 8: 运营人员 -->
        <!-- <view class="form-item">
          <text class="form-label">运营人员 <text class="required">*</text></text>
          <view class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
