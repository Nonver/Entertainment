	}

	.stats-value.highlight {
		color: #E8A838;
	}

	.stats-divider {
		width: 2rpx;
		height: 60rpx;
		background: #EEEEEE;
	}

	/* 列表卡片 */
	.list-card {
		margin: 0 24rpx 24rpx;
		background: #FFFFFF;
		border-radius: 16rpx;
		padding: 24rpx;
		box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
	}

	.empty-state {
		padding: 80rpx 0;
		flex-direction: column;
		align-items: center;
	}

	.empty-icon {
		font-size: 80rpx;
		margin-bottom: 20rpx;
	}

	.empty-text {
		font-size: 28rpx;
		color: #999999;
	}

	.record-item {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding: 24rpx 0;
		border-bottom: 1rpx solid #F5F5F5;
	}

	.record-item:last-child {
		border-bottom: none;
	}

	.record-left {
		flex-direction: row;
		align-items: center;
		flex: 1;
	}

	.record-icon {
		width: 72rpx;
		height: 72rpx;
		border-radius: 36rpx;
		background: linear-gradient(135deg, #F5C76B 0%, #E8A838 100%);
		justify-content: center;
		align-items: center;
		margin-right: 20rpx;
	}

	.icon-text {
		font-size: 28rpx;
		color: #FFFFFF;
		font-weight: 700;
	}

	.record-info {
		flex-direction: column;
		flex: 1;
	}

	.record-type {
		font-size: 28rpx;
		color: #333333;
		font-weight: 600;
		margin-bottom: 8rpx;
	}

	.record-desc {
		font-size: 24rpx;
		color: #999999;
		margin-bottom: 8rpx;
	}

	.record-time {
		font-size: 22rpx;
		color: #CCCCCC;
	}

	.record-amount {
		font-size: 32rpx;
		color: #E8A838;
		font-weight: 700;
	}

	/* 加载更多 */
	.loading-more,
	.load-more,
	.no-more {
		padding: 32rpx 0;
		align-items: center;
	}

	.loading-text,
	.load-more-text,
	.no-more-text {
		font-size: 24rpx;
