		width: 70rpx;
	}

	/* 搜索栏 */
	.search-bar {
		flex-direction: row;
		align-items: center;
		background-color: #FFFFFF;
		border-radius: 44rpx;
		padding: 18rpx 28rpx;
		margin: 16rpx 24rpx;
		border: 2rpx solid #E8D5A0;
	}

