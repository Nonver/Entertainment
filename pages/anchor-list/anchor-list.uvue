		font-size: 34rpx;
		color: #333333;
		font-weight: 500;
	}

	.nav-placeholder {
		width: 60rpx;
	}

	/* 搜索栏 */
	.search-section {
		padding: 20rpx 30rpx;
		background-color: #FFFFFF;
	}

