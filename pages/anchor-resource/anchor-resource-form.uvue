              <circle cx="12" cy="7" r="4"/>
            </svg>
            <input type="text" v-model="form.nickname" placeholder="请输入主播昵称" placeholder-class="ph" class="form-input" />
          </view>
        </view>

        <!-- Field 2.5: 真实姓名 -->
        <view class="form-item">
          <text class="form-label">真实姓名</text>
          <view class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <input type="text" v-model="form.real_name" placeholder="请输入真实姓名" placeholder-class="ph" class="form-input" />
          </view>
        </view>

        <!-- Field 2.6: 性别 -->
        <view class="form-item">
          <text class="form-label">性别</text>
          <view class="gender-row">
            <view class="gender-option" :class="{ active: form.gender === '男' }" @click="form.gender = '男'">
              <text :class="form.gender === '男' ? 'gender-text-active' : 'gender-text'">男</text>
            </view>
            <view class="gender-option" :class="{ active: form.gender === '女' }" @click="form.gender = '女'">
              <text :class="form.gender === '女' ? 'gender-text-active' : 'gender-text'">女</text>
            </view>
          </view>
        </view>

        <!-- Field 2.7: 年龄 -->
        <view class="form-item">
          <text class="form-label">年龄</text>
          <view class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
            <input type="number" v-model="form.age" placeholder="请输入年龄" placeholder-class="ph" class="form-input" />
          </view>
        </view>

        <!-- Field 3: 主播手机号 -->
        <view class="form-item">
          <text class="form-label">主播手机号 <text class="required">*</text></text>
          <view class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            <input type="tel" v-model="form.phone" maxlength="11" placeholder="请输入手机号" placeholder-class="ph" class="form-input" />
          </view>
        </view>

        <!-- Field 4: 主播微信 -->
        <view class="form-item">
          <text class="form-label">主播微信 <text class="required">*</text></text>
          <view class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/>
