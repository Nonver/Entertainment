/**
 * 登录相关 API 接口
 */

import { post, get, put } from "@/utils/request.uts"

// 登录请求参数
export type LoginParams = {
	username: string
	password: string
}

// 登录返回数据
export type LoginResult = {
	token: string
	admin: AdminInfo
}

// 管理员/用户信息
export type AdminInfo = {
	id: number
	username: string
	nickname: string
	role: number       // 0=超级管理员, 1=普通用户/工会
	avatar: string     // 头像URL
	orgId: number      // 推荐人ID
	parentId: string   // 父级ID
	phone?: string     // 手机号
	balance?: string   // 余额
	totalRecharge?: string   // 总充值
	agentCommission?: string // 佣金
	status?: number
	createdAt?: string
}

/**
 * 登录
 * POST /api/admin/login
 * 支持 admins 表和 users 表双重登录
 *   - admins 表：通过 username 字段匹配
 *   - users 表：通过 phone 字段匹配
 */
export const loginApi = (params: LoginParams): Promise<LoginResult> => {
	return post<LoginResult>('/login', params).then(res => res.data)
}

/**
 * 获取当前用户信息
 * GET /api/admin/auth/info
 */
export const getUserInfoApi = (): Promise<AdminInfo> => {
	return get<AdminInfo>('/auth/info').then(res => res.data)
}

// ==================== 新闻公告 ====================

// 公告
export type NoticeItem = {
	id: number
	title: string
	content: string
	type: string
	is_top: number
	status: number
	publish_time: string
	created_at: string
}

export type NoticeListResult = {
	list: NoticeItem[]
	total: number
	page: number
	page_size: number
}

// 新闻
export type NewsItem = {
	id: number
	title: string
	category: string
	author: string
	cover_url: string
	content: string
	views: number
	status: number
	publish_time: string
	create_time: string
}

export type NewsListResult = {
	list: NewsItem[]
	total: number
	currentPage: number
	pageSize: number
}

// 公告/新闻查询参数
export type NoticeQueryParams = {
	keyword?: string
	type?: string
	status?: number  // 0=草稿, 1=已发布
	page?: number
	page_size?: number
}

export type NewsQueryParams = {
	keyword?: string
	category?: string
	status?: number  // 0=草稿, 1=已发布
	currentPage?: number
	pageSize?: number
}

/**
 * 获取公告列表
 * GET /api/admin/notices
 */
export const getNoticesApi = (params?: NoticeQueryParams): Promise<NoticeListResult> => {
	return get<NoticeListResult>('/notices', params).then(res => res.data)
}

/**
 * 获取新闻列表
 * GET /api/admin/news
 */
export const getNewsApi = (params?: NewsQueryParams): Promise<NewsListResult> => {
	return get<NewsListResult>('/news', params).then(res => res.data)
}

// ==================== 平台列表 ====================

// 平台项
export type PlatformItem = {
	id: number
	platformName: string
	invitation: string
	downloadUrl: string
	platformImg: string
	platformqrCode: string
	status: string
	createTime: string
}

/**
 * 获取平台列表
 * GET /api/admin/platforms
 */
export const getPlatformsApi = (): Promise<PlatformItem[]> => {
	return get<PlatformItem[]>('/platforms').then(res => res.data)
}

// 直播平台项（来自 live_platforms 表）
export type LivePlatformItem = {
	id: number
	platformName: string
	invitation: string
	downloadUrl: string
	platformImg: string
	platformqrCode: string
	status: string
	createTime: string
}

/**
 * 获取直播平台列表
 * GET /api/admin/live-platforms
 */
export const getLivePlatformsApi = (): Promise<LivePlatformItem[]> => {
	return get<LivePlatformItem[]>('/live-platforms').then(res => res.data)
}

// ==================== 主播列表 ====================

// 主播项
export type AnchorItem = {
	id: number
	nickname: string
	anchorId: string
	phone: string
	userImg: string           // 主播头像
	avatar: string            // 头像（兼容字段）
	todayRevenue: number      // 今日业绩
	totalRevenue: string      // 总业绩
	status: string | number  // 0=审核中, 1=已审核, 2=未通过
	registerTime: string
	platformId: number
	platformName: string
}

// 主播查询参数
export type AnchorQueryParams = {
	platformId?: number
	keyword?: string
	status?: string  // pending, approved, rejected
	page?: number
	page_size?: number
}

// 主播列表结果
export type AnchorListResult = {
	list: AnchorItem[]
	total: number
	page: number
	page_size: number
}

/**
 * 获取主播列表（当前登录用户旗下的主播）
 * GET /api/admin/anchors
 */
export const getAnchorsApi = (params?: AnchorQueryParams): Promise<AnchorListResult> => {
	return get<AnchorListResult>('/anchors', params).then(res => res.data)
}

// 直播主播项（来自 live_anchors 表）
export type LiveAnchorItem = {
	id: number
	nickname: string
	anchorId: string
	phone: string
	userImg: string           // 主播头像
	avatar: string            // 头像（兼容字段）
	status: string | number  // 0=审核中, 1=已审核, 2=未通过
	registerTime: string
	platformId: number
	platformName: string
	operationType?: string    // 运营类型
}

// 直播主播列表结果
export type LiveAnchorListResult = {
	list: LiveAnchorItem[]
	total: number
	page: number
	page_size: number
}

/**
 * 获取直播主播列表
 * GET /api/admin/live-anchors
 */
export const getLiveAnchorsApi = (params?: AnchorQueryParams): Promise<LiveAnchorListResult> => {
	return get<LiveAnchorListResult>('/live-anchors', params).then(res => res.data)
}

// ==================== 添加主播（办理入职） ====================

// 添加主播请求参数
export type AddAnchorParams = {
	platformId: number      // 平台ID
	nickname: string        // 主播昵称
	anchorId: string        // 主播ID
	phone: string           // 手机号
	gender: number          // 性别：1=男, 2=女
	realName?: string       // 真实姓名
	unionId?: number         // 邀请人ID
}

/**
 * 添加主播（提交入职）- 语聊
 * POST /api/admin/anchors
 */
export const addAnchorApi = (params: AddAnchorParams): Promise<any> => {
	return post<any>('/anchors', params).then(res => res.data)
}

// ==================== 添加直播主播（办理入职） ====================

// 添加直播主播请求参数
export type AddLiveAnchorParams = {
	platformId: number      // 平台ID
	nickname: string        // 主播昵称
	anchorId: string        // 主播ID/账号
	phone: string           // 手机号
	realName?: string       // 真实姓名
	commissionRate?: number // 佣金比例（1-100）
	operationType?: number  // 运营模式：0=0.5/1分钟，1=分成35%
	userId?: number         // 关联用户ID
	unionId?: number        // 邀请人ID（当前登录用户）
}

/**
 * 添加直播主播（提交入职）
 * POST /api/admin/live-anchors
 */
export const addLiveAnchorApi = (params: AddLiveAnchorParams): Promise<any> => {
	return post<any>('/live-anchors', params).then(res => res.data)
}

// ==================== 我的团队 ====================

// 团队统计数据（来自 /api/admin/users/my-account-stats）
export type MyAccountStats = {
	subUserCount: number     // 下级用户数（直推代理）
	anchorCount: number      // 旗下主播数
	totalCommission: string  // 累计佣金
}

/**
 * 获取我的账户统计（团队统计）
 * GET /api/admin/users/my-account-stats
 */
export const getMyAccountStatsApi = (): Promise<MyAccountStats> => {
	return get<MyAccountStats>('/users/my-account-stats').then(res => res.data)
}

/**
 * 获取我的间推代理统计（一次性返回，无需多次请求）
 * GET /api/admin/users/my-indirect-stats
 * 逻辑：找出我的直推用户 -> 汇总每个直推用户的下级用户数 = 间推代理数
 */
export const getMyIndirectStatsApi = (): Promise<{ indirectAgentCount: number }> => {
	return get<{ indirectAgentCount: number }>('/users/my-indirect-stats').then(res => res.data)
}

// 用户列表项（用于展示代理）
export type UserItem = {
	id: number
	nickname: string
	phone: string
	phoneMasked: string
	role: number
	orgId: number
	parentId: string
	avatar: string           // 头像URL
	balance: string
	totalRecharge: string
	agentCommission: string
	status: number
	statusText: string
	createdAt: string
}

// 用户列表结果
export type UserListResult = {
	list: UserItem[]
	total: number
	page: number
	pageSize: number
}

/**
 * 获取用户列表（用于团队页-代理列表）
 * GET /api/admin/users
 */
export const getUsersApi = (params?: any): Promise<UserListResult> => {
	return get<UserListResult>('/users', params).then(res => res.data)
}

/**
 * 校验工会ID（用于查看推荐人信息）
 * GET /api/admin/users/check-org/{id}
 */
export const checkOrgApi = (id: number): Promise<{valid: boolean, nickname: string}> => {
	return get<{valid: boolean, nickname: string}>(`/users/check-org/${id}`).then(res => res.data)
}

// 团队成员展示项
export type TeamMemberItem = {
	id: number
	anchorId: string         // 主播ID
	nickname: string         // 昵称
	userImg: string          // 头像
	todayRevenue: string     // 今日业绩
	totalRevenue: string     // 总业绩
	platformId: number       // 平台ID
	platformName: string     // 平台名称
	phone: string            // 手机号
	status: number           // 状态
}

// 代理展示项
export type AgentItem = {
	id: number
	nickname: string
	phone: string
	phoneMasked: string
	agentCommission: string
	totalRecharge: string
