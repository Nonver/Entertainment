	}

	.time-txt {
		font-size: 23rpx;
		color: #BBBBBB;
	}

	.loading-more {
		padding: 32rpx;
		align-items: center;
		justify-content: center;
	}

	.loading-text {
		font-size: 26rpx;
		color: #CCCCCC;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(10rpx);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>