		<!-- 操作卡片区 -->
		<view class="action-flex">
			<view class="flex-img" @click="goWithdraw">

			</view>
			<view class="flex-img" @click="goFinanceDetail">

			</view>
		</view>

		<!-- 平台列表区 -->
		<view class="platform-section">
			<text class="section-title">平台列表</text>

			<!-- 平台类型切换 -->
			<view class="platform-type-tabs">
				<view class="type-tab" :class="{ 'type-tab-active': currentPlatformType === 'chat' }"
					@click="switchPlatformType('chat')">
					<text class="type-tab-text">语聊</text>
				</view>
				<view class="type-tab" :class="{ 'type-tab-active': currentPlatformType === 'live' }"
					@click="switchPlatformType('live')">
					<text class="type-tab-text">直播（返10%）</text>
				</view>
			</view>

			<!-- 平台卡片列表 -->
			<view class="platform-grid">
				<view class="platform-card" v-for="(item, index) in currentPlatformList" :key="index">
					<text class="platform-name">{{ item.name }}</text>
					<image class="platform-logo" :src="item.logo" mode="aspectFit"></image>
					<view class="platform-actions">
						<view class="platform-btn" v-for="(btn, btnIdx) in item.buttons" :key="btnIdx"
							@click="handlePlatformAction(item, btn)">
							<text class="platform-btn-text">{{ btn }}</text>
						</view>
					</view>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref } from "vue";
	import { checkLogin } from "@/utils/auth.uts";
	import { getPlatformsApi, getLivePlatformsApi, PlatformItem, LivePlatformItem } from "@/utils/api.uts";

	// 页面显示时检查登录状态并加载数据
	onShow(() => {
		if (checkLogin()) {
			loadPlatforms()
		}
	})

	// 公告轮播图片
	const noticeImages = ref<string[]>([
		'/static/announcement-1.jpg',
		'/static/announcement-2.jpg',
		'/static/announcement-3.jpg',
		'/static/announcement-4.jpg'
	])

	// 平台列表数据（从 API 加载）
	type PlatformCard = {
		name : string,
		logo : string,
		inviteCode : string,
		downloadUrl : string,
		qrCode : string,
		buttons : string[],
		id : number
	}

	const chatPlatformList = ref<PlatformCard[]>([])
	const livePlatformList = ref<PlatformCard[]>([])
	const currentPlatformType = ref<'chat' | 'live'>('chat')

	// 计算当前显示的平台列表
	const currentPlatformList = computed<PlatformCard[]>(() => {
		return currentPlatformType.value === 'chat' ? chatPlatformList.value : livePlatformList.value
	})

	// 切换平台类型
	const switchPlatformType = (type : 'chat' | 'live') : void => {
		currentPlatformType.value = type
	}

	// 从 API 加载平台列表
	const loadPlatforms = () : void => {
		// 加载语聊平台
		getPlatformsApi().then((list) => {
			if (list.length > 0) {
				chatPlatformList.value = list.map((item : PlatformItem) : PlatformCard => ({
					id: item.id,
					name: item.platformName,
					logo: item.platformImg || '/static/default-platform.png',
					inviteCode: item.invitation || '',
					downloadUrl: item.downloadUrl || '',
					qrCode: item.platformqrCode || '',
					buttons: ['APP下载', '快捷绑定', '应用介绍', '用户列表']
				}))
			}
		}).catch((err) => {
			console.error('加载语聊平台列表失败:', err)
		})

		// 加载直播平台
		getLivePlatformsApi().then((list) => {
			if (list.length > 0) {
				livePlatformList.value = list.map((item : LivePlatformItem) : PlatformCard => ({
					id: item.id,
					name: item.platformName,
					logo: item.platformImg || '/static/default-platform.png',
					inviteCode: item.invitation || '',
					downloadUrl: item.downloadUrl || '',
					qrCode: item.platformqrCode || '',
					buttons: ['APP下载', '快捷绑定', '应用介绍', '用户列表']
				}))
			}
		}).catch((err) => {
			console.error('加载直播平台列表失败:', err)
		})
	}

	// 页面跳转方法
	const goPromote = () : void => {
		uni.navigateTo({ url: '/pages/promote/promote' })
	}

	const goTeam = () : void => {
		uni.navigateTo({ url: '/pages/team/team' })
	}

	const goAnchorResource = () : void => {
		uni.navigateTo({ url: '/pages/anchor-resource/anchor-resource' })
	}

	// 跳转到消息通知
	const goNotice = () : void => {
		uni.navigateTo({ url: '/pages/notice/notice' })
	}

	const goPerformance = () : void => {
		uni.switchTab({ url: '/pages/performance/performance' })
	}

	const goService = () : void => {
		uni.navigateTo({ url: '/pages/service/service' })
	}

	const goWithdraw = () : void => {
		uni.navigateTo({ url: '/pages/withdraw/withdraw' })
	}

	const goFinanceDetail = () : void => {
		uni.navigateTo({ url: '/pages/finance-detail/finance-detail' })
	}

	const handlePlatformAction = (item : PlatformCard, action : string) : void => {
		if (action === 'APP下载') {
			const url = `/pages/app-download/app-download?name=${encodeURIComponent(item.name)}&code=${item.inviteCode}&url=${encodeURIComponent(item.downloadUrl)}&qrCode=${encodeURIComponent(item.qrCode)}`
			console.log('navigate to:', url)
			uni.navigateTo({ url: url })
		} else if (action === '应用介绍') {
			const url = `/pages/app-intro/app-intro?name=${encodeURIComponent(item.name)}`
			console.log('navigate to intro:', url)
			uni.navigateTo({ url: url })
		} else if (action === '快捷绑定') {
			const url = `/pages/quick-bind/quick-bind?name=${encodeURIComponent(item.name)}&platformId=${item.id}&platformType=${currentPlatformType.value}`
			console.log('navigate to bind:', url)
			uni.navigateTo({ url: url })
		} else if (action === '用户列表') {
			const url = `/pages/anchor-list/anchor-list?name=${encodeURIComponent(item.name)}&platformId=${item.id}&platformType=${currentPlatformType.value}`
			console.log('navigate to anchor list:', url)
			uni.navigateTo({ url: url })
		} else {
			console.log('platform action:', item.name, action)
			uni.showToast({
				title: `${action}功能开发中`,
				icon: 'none'
			})
		}
	}
</script>

