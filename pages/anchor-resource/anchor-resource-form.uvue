          <view class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
            <input type="text" v-model="form.platform" placeholder="请输入主播平台" placeholder-class="ph" class="form-input" />
          </view>
        </view>

        <!-- Field 2: 主播昵称 -->
        <view class="form-item">
          <text class="form-label">主播昵称 <text class="required">*</text></text>
          <view class="input-wrapper">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
