  font-size: 36rpx;
}

.st-pending { color: #FF9800; }
.st-approved { color: #4CAF50; font-weight: bold; }
.st-rejected { color: #F44336; }

.status-text {
  font-size: 30rpx;
  font-weight: bold;
}

.section {
  padding: 28rpx;
  border-top: 1rpx solid #F0F0F0;
}

