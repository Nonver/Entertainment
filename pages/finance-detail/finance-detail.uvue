<template>
	<view class="container">
		<!-- 导航栏 -->
		<view class="nav-bar">
			<view class="back-btn" @click="goBack">
				<image class="menu-arrow-icon" src="/static/svg/jt.png" mode="aspectFit" style="transform: rotate(180deg);" />
			</view>
			<text class="nav-title">资金明细</text>
			<view class="nav-placeholder"></view>
		</view>

		<!-- 搜索栏 -->
		<view class="search-bar">
			<text class="search-icon">🔍</text>
			<input class="search-input" type="text" placeholder="请输入代理id或昵称" v-model="searchKeyword"
				@input="onSearchInput" />
		</view>

		<!-- 平台切换栏 -->
		<view class="platform-bar">
			<image class="platform-logo" :src="currentPlatform?.platformImg || '/static/logo.png'" mode="aspectFit" />
			<text class="platform-name">{{ currentPlatform?.platformName || '加载中...' }}</text>
			<view class="switch-btn" @click="showPlatformPicker = true">
				<text class="switch-text">切换平台</text>
			</view>
		</view>

		<!-- Tab 切换（双行布局） -->
		<view class="tab-scroll">
			<view class="tab-row">
				<view v-for="(tab, index) in tabsRow1" :key="'r1-'+index" class="tab-item"
					:class="{ 'tab-active': currentTab === index }" @click="switchTab(index)">
					<text class="tab-text" :class="{ 'tab-text-active': currentTab === index }">{{ tab }}</text>
				</view>
			</view>
			<view class="tab-row">
				<view v-for="(tab, index) in tabsRow2" :key="'r2-'+index" class="tab-item"
					:class="{ 'tab-active': currentTab === (index + tabsRow1.length) }" @click="switchTab(index + tabsRow1.length)">
					<text class="tab-text" :class="{ 'tab-text-active': currentTab === (index + tabsRow1.length) }">{{ tab }}</text>
				</view>
			</view>
		</view>

		<!-- 资金列表 -->
		<scroll-view class="list-container" scroll-y @scrolltolower="loadMore">
			<view v-for="(item, index) in recordList" :key="item.uid" class="record-card">
				<view class="record-row1">
					<text class="record-type">{{ item.type_name }}{{ item.direction === 'in' ? '(收入)' : '(支出)' }}</text>
					<text class="record-amount"
						:class="item.direction === 'in' ? 'amount-in' : 'amount-out'">{{ item.direction === 'in' ? '+' : '-' }}{{ item.amount }}</text>
				</view>
				<view class="record-row2">
					<text class="record-balance">编号：{{ item.order_no }}</text>
					<text v-if="item.anchor_nickname" class="record-agent">主播：{{ item.anchor_nickname }}</text>
				</view>
				<view class="record-row3">
					<text class="record-no">{{ item.user_nickname ? (item.user_nickname + '的') : '' }}{{ item.type_name }}</text>
					<text class="record-time">{{ formatTime(item.created_at) }}</text>
				</view>
			</view>

			<!-- 加载中 -->
			<view v-if="loading && recordList.length === 0" class="empty-state">
				<text class="empty-text">加载中...</text>
			</view>
			<!-- 空状态 -->
			<view v-if="!loading && recordList.length === 0" class="empty-state">
				<image class="empty-icon" src="/static/empty-list.png" mode="aspectFit" />
				<text class="empty-text">暂无数据</text>
			</view>
			<!-- 没有更多了 -->
			<view v-if="!loading && recordList.length > 0 && !hasMore" class="no-more">
				<text class="no-more-text">没有更多了</text>
			</view>
		</scroll-view>

		<!-- 切换平台弹窗 -->
		<view v-if="showPlatformPicker" class="popup-mask" @click="showPlatformPicker = false">
			<view class="popup-content" @click.stop>
				<view class="popup-header">
					<text class="popup-cancel" @click="showPlatformPicker = false">取消</text>
					<text class="popup-title">切换平台</text>
					<text class="popup-close" @click="showPlatformPicker = false">✕</text>
				</view>
				<scroll-view class="popup-list" scroll-y>
					<view v-for="(platform, index) in platforms" :key="index" class="popup-item"
						@click="selectPlatform(index)">
						<image class="popup-item-logo" :src="platform.platformImg || '/static/logo.png'" mode="aspectFit" />
						<text class="popup-item-name">{{ platform.platformName }}</text>
					</view>
				</scroll-view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref, computed, onMounted } from "vue";
	import { checkLogin } from "@/utils/auth.uts";
	import {
		getFundDetailApi,
		getPlatformsApi,
		type FundDetailItem,
		type PlatformItem,
	} from "@/utils/api.uts"

	// ========== 平台数据 ==========
	const platforms = ref<PlatformItem[]>([])
	const currentPlatform = ref<PlatformItem | null>(null)
	const showPlatformPicker = ref<boolean>(false)

	// ========== 列表数据 ==========
	const allRecords = ref<FundDetailItem[]>([])
	const loading = ref<boolean>(false)
	const currentPage = ref<number>(1)
	const pageSize = 20
	const total = ref<number>(0)
	const hasMore = computed<boolean>(() : boolean => {
		return allRecords.value.length < total.value
	})

	// ========== Tab（从 API 数据类型动态生成）==========
	// ftype → 显示名称映射
	const ftypeLabels: Record<string, string> = {
		'direct': '直推佣金',
		'indirect': '间推佣金',
		'commission': '其他佣金',
		'withdraw': '提现(已通过)',
	}

	const tabs = ref<string[]>([])
	const tabTypes = ref<string[]>([])  // 每个Tab对应的ftype值
	const tabsRow1 = computed<string[]>(() : string[] => { return tabs.value.slice(0, 5) })
	const tabsRow2 = computed<string[]>(() : string[] => { return tabs.value.slice(5) })
	const currentTab = ref<number>(0)
	const searchKeyword = ref<string>('')

	// 更新Tab列表（从数据中提取不重复的ftype）
	const updateTabs = (list: FundDetailItem[]) : void => {
		const types = new Set<string>()
		types.add('all')  // 第一个Tab始终为"全部"
		list.forEach((item: FundDetailItem) : void => {
			if (item.ftype) types.add(item.ftype)
		})
		const typeArr = Array.from(types)
		tabTypes.value = typeArr
		tabs.value = typeArr.map((t: string) : string => {
			if (t === 'all') return '全部'
			return ftypeLabels[t] || t
		})
	}

	// 当前Tab对应的API type参数
	const getApiType = (tabIndex: number) : string => {
		return tabTypes.value[tabIndex] || 'all'
	}

	// 过滤后的列表
	const recordList = computed<FundDetailItem[]>(() : FundDetailItem[] => {
		let list = allRecords.value
		const search = searchKeyword.value.trim()
		if (search !== '') {
			list = list.filter((item : FundDetailItem) : boolean => {
				return (item.anchor_nickname && item.anchor_nickname.indexOf(search) !== -1)
					|| (item.user_nickname && item.user_nickname.indexOf(search) !== -1)
					|| (item.order_no && item.order_no.indexOf(search) !== -1)
			})
		}
		return list
	})

	// ========== 加载数据 ==========
	const loadRecords = (resetPage: boolean = false) : void => {
		if (resetPage) {
			currentPage.value = 1
			allRecords.value = []
		}
		if (loading.value) return
		loading.value = true

		const type = getApiType(currentTab.value)
		getFundDetailApi({
			platform_id: currentPlatform.value?.id || 0,
			type: type,
			keyword: searchKeyword.value.trim(),
			page: currentPage.value,
			page_size: pageSize,
		}).then((res) => {
			total.value = res.total
			if (resetPage) {
				allRecords.value = res.list
				// 首次加载或切换条件时，根据返回数据更新Tab
				updateTabs(res.list)
			} else {
				allRecords.value = allRecords.value.concat(res.list)
			}
		}).catch((_err : any) => {}).finally(() => {
			loading.value = false
		})
	}

	// 加载平台列表
	const loadPlatforms = () : void => {
		getPlatformsApi().then((list : PlatformItem[]) => {
			platforms.value = list
			if (list.length > 0 && !currentPlatform.value) {
				currentPlatform.value = list[0]
				loadRecords(true)
			}
		}).catch((_err : any) => {})
	}

	onMounted(() => {
		checkLogin()
		loadPlatforms()
	})

	// ========== 交互 ==========
	const goBack = () : void => {
		const pages = getCurrentPages()
		if (pages.length > 1) {
			uni.navigateBack()
		} else {
			uni.reLaunch({ url: '/pages/index/index' })
		}
	}

	const selectPlatform = (index : number) : void => {
		currentPlatform.value = platforms.value[index]
		showPlatformPicker.value = false
		currentTab.value = 0
		searchKeyword.value = ''
		loadRecords(true)
	}

	const switchTab = (index : number) : void => {
		if (currentTab.value === index) return
		currentTab.value = index
		loadRecords(true)
	}

	const onSearchInput = (e : any) : void => {
		searchKeyword.value = e.detail.value as string
		loadRecords(true)
	}

	// 加载更多（滚动到底部触发）
	const loadMore = () : void => {
		if (loading.value || !hasMore.value) return
		currentPage.value++
		loadRecords()
	}

	// 格式化时间
	const formatTime = (time : string | null) : string => {
		if (time == null || time === '') return ''
		return time.replace('T', ' ').substring(0, 16)
	}
</script>

<style>
