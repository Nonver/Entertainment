		margin-left: 20rpx;
	}

	.filter-btn-text {
		font-size: 24rpx;
		color: #FFFFFF;
		font-weight: 600;
	}

	/* 统计卡片 */
	.stats-card {
		margin: 0 24rpx 24rpx;
		background: #FFFFFF;
		border-radius: 16rpx;
		padding: 32rpx;
		flex-direction: row;
		align-items: center;
		justify-content: space-around;
		box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
	}

	.stats-item {
		flex-direction: column;
		align-items: center;
	}

	.stats-label {
		font-size: 24rpx;
		color: #999999;
		margin-bottom: 12rpx;
	}

	.stats-value {
		font-size: 40rpx;
