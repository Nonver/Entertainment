				</view>
				<view class="summary-item">
					<text class="summary-label">团队总业绩(元)</text>
					<text class="summary-value">{{ summary.totalTeamPerformance }}</text>
				</view>
			</view>
		</view>

		<!-- 平台切换栏 -->
		<view class="platform-bar">
			<image class="platform-logo" :src="currentPlatform.logo" mode="aspectFit" />
			<view class="platform-info">
				<text class="platform-name">{{ currentPlatform.name }}</text>
				<text class="platform-level" v-if="currentPlatform.level !== ''">LV{{ currentPlatform.level }}</text>
			</view>
			<view class="switch-btn" @click="showPlatformPicker = true">
				<text class="switch-text">切换平台</text>
			</view>
		</view>

		<!-- 平台佣金比例 -->
		<view class="commission-card">
			<text class="commission-title">平台佣金比例</text>
			<view class="commission-row">
				<text class="commission-item">直推 <text
						class="commission-value">{{ currentPlatform.directRate }}%</text></text>
				<text class="commission-item">平级 <text
						class="commission-value">{{ currentPlatform.sameLevelRate }}%</text></text>
			</view>
		</view>

		<!-- 当前平台数据 -->
		<!-- <view class="platform-data-card">
			<view class="data-grid">
				<view class="data-item">
					<text class="data-label">今日收益(元)</text>
					<text class="data-value">{{ currentPlatform.todayIncome }}</text>
				</view>
				<view class="data-item">
