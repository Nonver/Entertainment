		background-color: #FFD54F;
		color: #333333;
		font-weight: 700;
	}

	.main-content {
		flex: 1;
		padding: 16rpx 24rpx;
	}

	.empty-state {
		padding-top: 200rpx;
		align-items: center;
		justify-content: center;
	}

	.empty-text {
		font-size: 28rpx;
		color: #BBBBBB;
	}

	.list-container {
		padding-bottom: 40rpx;
	}

	.card {
		background: #FFFFFF;
		border-radius: 16rpx;
		padding: 24rpx;
		margin-bottom: 14rpx;
		box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.04);
		opacity: 0;
		transform: translateY(10rpx);
		animation: fadeInUp 0.3s ease forwards;
	}

	.card-row {
		flex-direction: row;
		align-items: center;
	}

	.avatar-box {
		width: 90rpx;
		height: 90rpx;
		border-radius: 50%;
		background: linear-gradient(135deg, #FFD54F 0%, #FFB300 100%);
		align-items: center;
		justify-content: center;
		position: relative;
		flex-shrink: 0;
	}

	.avatar-letter {
		font-size: 36rpx;
		font-weight: 700;
		color: #FFFFFF;
	}

	.pending-dot {
		position: absolute;
		top: -2rpx;
		right: -2rpx;
		width: 18rpx;
		height: 18rpx;
		background: #FF3B30;
		border-radius: 50%;
		border: 3rpx solid #FFFFFF;
	}

	.info-col {
		flex: 1;
		margin-left: 20rpx;
	}

	.row-top {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 6rpx;
	}

	.name {
		font-size: 30rpx;
