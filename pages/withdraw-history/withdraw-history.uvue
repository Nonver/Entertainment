		justify-content: space-between;
		padding: 18rpx 24rpx;
		border-top: 1rpx solid #F5F5F5;
	}

	.fee-label {
		font-size: 22rpx;
		color: #BBBBBB;
	}

	.amount-group {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
	}

	.actual-label {
		font-size: 20rpx;
		color: #AAAAAA;
		margin-bottom: 4rpx;
	}

	.item-amount {
		font-size: 34rpx;
		color: #F0C275;
		font-weight: 600;
	}

	.amount-rejected {
		color: #FF6B6B !important;
	}

	.empty-icon {
		width: 200rpx;
		height: 200rpx;
		margin-bottom: 20rpx;
	}

	/* 空状态 */
	.empty-state {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 100rpx 0;
	}

	.empty-text {
		font-size: 28rpx;
		color: #999999;
	}

	/* 没有更多了 */
	.no-more {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 40rpx 0 60rpx 0;
	}

	.no-more-text {
		font-size: 24rpx;
		color: #999999;
	}
</style>
