				<view class="data-item">
					<text class="data-label">我团队总业绩(元)</text>
					<text class="data-value">{{ currentPlatform.myTeamTotalPerformance }}</text>
				</view>
			</view>
		</view> -->

		<!-- Tab 切换 -->
		<view class="tab-section">
			<view v-for="(tab, index) in tabs" :key="index" class="tab-item"
				:class="{ 'tab-active': currentTab === index }" @click="currentTab = index">
				<text class="tab-text" :class="{ 'tab-text-active': currentTab === index }">{{ tab }}</text>
			</view>
		</view>

		<!-- 主播/代理列表 -->
		<view class="list-container">
			<!-- 我的主播业绩 -->
			<template v-if="currentTab === 0">
				<view v-for="(anchor, index) in currentPlatform.anchors" :key="index" class="anchor-card">
					<view class="anchor-header">
						<image class="anchor-avatar" :src="anchor.avatar" mode="aspectFill" />
						<view class="anchor-info">
							<text class="anchor-name">{{ anchor.name }}</text>
							<text class="anchor-id">ID：{{ anchor.id }}</text>
						</view>
					</view>
					<view class="anchor-stats">
						<view class="anchor-stat-item">
							<text class="stat-label">今日个人业绩(元)</text>
							<text class="stat-value">{{ anchor.todayPerformance }}</text>
						</view>
						<view class="anchor-stat-item">
							<text class="stat-label">个人总业绩(元)</text>
							<text class="stat-value">{{ anchor.totalPerformance }}</text>
						</view>
					</view>
				</view>
</template>

			<!-- 直推代理业绩 -->
			<template v-else-if="currentTab === 1">
				<view v-for="(agent, index) in currentPlatform.agents" :key="index" class="agent-card">
					<view class="agent-header">
						<image class="agent-avatar" :src="agent.avatar" mode="aspectFill" />
						<view class="agent-info">
							<text class="agent-name">{{ agent.name }}</text>
							<text class="agent-id">ID：{{ agent.id }}</text>
						</view>
					</view>
					<view class="agent-stats">
						<view class="agent-stat-item">
							<text class="stat-label">今日业绩(元)</text>
							<text class="stat-value">{{ agent.todayPerformance }}</text>
						</view>
						<view class="agent-stat-item">
							<text class="stat-label">总业绩(元)</text>
							<text class="stat-value">{{ agent.totalPerformance }}</text>
						</view>
					</view>
				</view>
</template>

			<!-- 空状态 -->
			<view v-if="getShowEmpty()" class="empty-state">
				<text class="empty-text">暂无数据</text>
			</view>
		</view>

		<!-- 切换平台弹窗 -->
		<view v-if="showPlatformPicker" class="popup-mask" @click="showPlatformPicker = false">
			<view class="popup-content" @click.stop>
				<view class="popup-header">
					<text class="popup-cancel" @click="showPlatformPicker = false">取消</text>
					<text class="popup-title">切换平台</text>
					<text class="popup-close" @click="showPlatformPicker = false">✕</text>
				</view>
				<scroll-view class="popup-list" scroll-y>
					<view v-for="(platform, index) in platforms" :key="index" class="popup-item"
						@click="selectPlatform(index)">
						<image class="popup-item-logo" :src="platform.logo" mode="aspectFit" />
						<text class="popup-item-name">{{ platform.name }}</text>
					</view>
				</scroll-view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { onShow } from "@dcloudio/uni-app";
	import { checkLogin } from "@/utils/auth.uts";
	import {
		getSummaryStatsApi,
		getPerformanceStatsApi,
		getCommissionApi,
		getLevelApi,
		getAnchorsApi,
		getUsersApi,
		type SummaryStats,
		type PlatformItem,
		type AnchorItem as ApiAnchorItem,
		type UserItem as ApiUserItem
	} from "@/utils/api.uts"
	import { getPlatformsApi } from "@/utils/api.uts"

	// 页面显示时检查登录状态并加载数据
	onShow(() => {
		checkLogin()
		loadAllData()
	})

	// ========== 业绩汇总 ==========
	const summary = ref({
		todayIncome: '0',
		todayPersonal: '0',
		todayTeam: '0',
		totalIncome: '0',
		teamAnchors: '0',
		totalTeamPerformance: '0'
	})

	const loadSummaryStats = () => {
		getSummaryStatsApi().then((data : SummaryStats) => {
			summary.value = {
				todayIncome: data.todayIncome.toFixed(4).replace(/\.?0+$/, ''),
				todayPersonal: data.todayPersonal.toFixed(2),
				todayTeam: data.todayTeam.toFixed(2),
				totalIncome: data.totalIncome.toFixed(4).replace(/\.?0+$/, ''),
				teamAnchors: String(data.teamAnchorCount),
				totalTeamPerformance: data.totalTeam.toFixed(4).replace(/\.?0+$/, '')
			}
		}).catch((_err : any) => { })
	}

	// ========== 平台数据接口 ==========
	interface AnchorPerfItem {
		name : string
		id : string
		avatar : string
		todayPerformance : string
		totalPerformance : string
	}

	interface AgentPerfItem {
		name : string
		id : string
		avatar : string
		todayPerformance : string
		totalPerformance : string
	}

	interface PlatformData {
		id : number
		name : string
		logo : string
		level : string
		directRate : number
		sameLevelRate : number
		anchors : AnchorPerfItem[]
		agents : AgentPerfItem[]
	}

	const platforms = ref<PlatformData[]>([])
	const currentPlatform = ref<PlatformData>({
		id: 0,
		name: '',
		logo: '',
		level: '',
		directRate: 0,
		sameLevelRate: 0,
		anchors: [],
		agents: []
	})
	const showPlatformPicker = ref<boolean>(false)

	// Tab
	const tabs = ref<string[]>(['我的主播业绩', '间推代理业绩'])
	const currentTab = ref<number>(0)

	// ========== 加载所有数据 ==========
	const loadAllData = () => {
		loadSummaryStats()
		loadPlatforms()
	}

	// 加载平台列表
	const loadPlatforms = () => {
		getPlatformsApi().then((list : PlatformItem[]) => {
			if (list.length === 0) return
			const mapped = list.map((p) : PlatformData => ({
				id: p.id,
				name: p.platformName,
				logo: p.platformImg || '/static/userinfo.png',
				level: '',
				directRate: 0,
				sameLevelRate: 0,
				anchors: [],
				agents: []
			}))
			platforms.value = mapped
			// 默认选中第一个，加载其数据
			selectPlatformData(0)
		}).catch((_err : any) => { })
	}

	// 选择平台并加载数据
	const selectPlatformData = (index : number) : void => {
		if (platforms.value.length === 0) return
		currentPlatform.value = { ...platforms.value[index] }
		const platformId = platforms.value[index].id

		// 并行请求：统计、佣金、等级、主播列表
		Promise.all([
			getPerformanceStatsApi(platformId),
			getCommissionApi(platformId),
			getLevelApi(platformId),
			getAnchorsApi({ platformId, page: 1, page_size: 50 })
		]).then(([stats, commission, level, anchorResult]) : void => {
			const idx = platforms.value.findIndex((p : PlatformData) => p.id === platformId)
			if (idx >= 0) {
				platforms.value[idx].directRate = commission.directRate
				platforms.value[idx].sameLevelRate = commission.peerRate
				platforms.value[idx].level = String(level.level)

				// 映射主播列表
				platforms.value[idx].anchors = anchorResult.list.map((a : ApiAnchorItem) : AnchorPerfItem => ({
					name: a.nickname,
					id: a.anchorId,
					avatar: a.userImg || '/static/userinfo.png',
					todayPerformance: String(a.todayRevenue ?? '0'),
					totalPerformance: String(a.totalRevenue ?? '0')
				}))

				currentPlatform.value = { ...platforms.value[idx] }
			}
		}).catch((_err : any) => { })

		// 加载代理列表（role=1 是间推代理）
		loadAgents(platformId)
	}

	// 加载间推代理列表
	const loadAgents = (platformId : number) => {
		getUsersApi({ role: 1, page: 1, pageSize: 50 }).then((result) => {
			const idx = platforms.value.findIndex((p : PlatformData) => p.id === platformId)
			if (idx >= 0) {
				platforms.value[idx].agents = result.list.map((u : ApiUserItem) : AgentPerfItem => ({
					name: u.nickname,
					id: String(u.id),
					avatar: u.avatar || '/static/userinfo.png',
					todayPerformance: u.agentCommission || '0.00',
					totalPerformance: u.totalRecharge || '0.00'
				}))
				currentPlatform.value = { ...platforms.value[idx] }
			}
		}).catch((_err : any) => { })
	}

	// 选择平台（弹窗点击）
	const selectPlatform = (index : number) : void => {
		showPlatformPicker.value = false
		currentTab.value = 0
		selectPlatformData(index)
	}

	// 是否显示空状态
	const getShowEmpty = () : boolean => {
		if (currentTab.value === 0) {
			return currentPlatform.value.anchors.length === 0
		} else if (currentTab.value === 1) {
			return currentPlatform.value.agents.length === 0
		}
		return true
	}
</script>

