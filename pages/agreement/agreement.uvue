</template>

<script setup lang="uts">
	import { ref } from "vue";

	// 页面标题
	const pageTitle = ref<string>('用户注册协议')

	// 是否为新闻详情模式（从 news 列表点击进入）
	const isNewsDetail = ref<boolean>(false)

	// 详情数据
	const detailData = ref<any>({
		title: '',
		content: '',
		publish_time: '',
		author: ''
	})

	// 通过 onLoad 接收页面参数
	onLoad((options : any) => {
		console.log('[agreement] onLoad options:', JSON.stringify(options))
		const dataStr = options?.data as string | null
		if (dataStr != null && dataStr !== '') {
			try {
				const data = JSON.parse(decodeURIComponent(dataStr))
				console.log('[agreement] parsed data:', JSON.stringify(data))
				pageTitle.value = data.title || '详情'
				detailData.value = data
				isNewsDetail.value = true
			} catch (e) {
				console.error('解析新闻数据失败:', e)
			}
		}
	})

	// 返回上一页
	const goBack = () : void => {
		const pages = getCurrentPages()
		if (pages.length > 1) {
			uni.navigateBack()
		} else {
			uni.switchTab({
				url: '/pages/news/news'
			})
		}
	}
</script>

