      <!-- Bottom Spacer -->
      <view class="bottom-spacer"></view>
    </scroll-view>

    <!-- Fixed Bottom Action Bar -->
    <view class="action-bar">
      <button class="submit-btn" @click="handleSubmit" :disabled="submitting">
        {{ submitting ? '提交中...' : '提交审核' }}
      </button>
    </view>
  </view>
</template>

<script setup lang="uts">
import { ref, reactive } from 'vue'
import { post, upload } from '../../utils/request'
import { checkLogin } from '../../utils/auth.uts'

const submitting = ref(false)

// 登录检查
onShow(() => {
  checkLogin()
})

const statusBarHeight = ref<number>(0)

onMounted(() => {
  // 获取状态栏高度
  const sysInfo = uni.getSystemInfoSync()
  statusBarHeight.value = sysInfo.statusBarHeight || 0
  
  checkLogin()
})

const form = reactive({
  platform: '',
  nickname: '',
  real_name: '',
  gender: '',
  age: '',
  phone: '',
  wechat: '',
  photo: '',
  flow_photo: '',
  union_name: '',
  current_salary: '',
  expire_date: '',
  // operator: ''
})

function goBack() {
	// 返回上一页
	const pages = getCurrentPages()
	if (pages.length > 1) {
		uni.navigateBack()
	} else {
		uni.reLaunch({ url: '/pages/anchor-resource/anchor-resource' })
	}
}

function onDateChange(e: any) {
  form.expire_date = e.detail.value as string
}

function choosePhoto() {
  uni.chooseImage({
    count: 1,
    sizeType: ['compressed'],
    sourceType: ['album', 'camera'],
    success: (res: ChooseImageSuccessCallbackResult) => {
      upload(res.tempFilePaths[0]).then((res: any) => {
        form.photo = res.data.url as string
        uni.showToast({ title: '上传成功', icon: 'success' })
      })
    }
  })
}

function chooseFlowPhoto() {
  uni.chooseImage({
    count: 1,
    sizeType: ['compressed'],
    sourceType: ['album', 'camera'],
    success: (res: ChooseImageSuccessCallbackResult) => {
      upload(res.tempFilePaths[0]).then((res: any) => {
        console.log('流水上传返回:', JSON.stringify(res))
        form.flow_photo = res.data.url as string
        uni.showToast({ title: '上传成功', icon: 'success' })
      }).catch((err: any) => {
        console.log('流水上传失败:', JSON.stringify(err))
        uni.showToast({ title: '流水上传失败', icon: 'none' })
      })
    }
  })
}

function validateForm(): boolean {
  if (!form.platform.trim()) {
    uni.showToast({ title: '请输入主播平台', icon: 'none' })
    return false
  }
  if (!form.nickname.trim()) {
    uni.showToast({ title: '请输入主播昵称', icon: 'none' })
    return false
  }
  if (!form.phone.trim()) {
    uni.showToast({ title: '请输入手机号', icon: 'none' })
    return false
  }
  if (!form.wechat.trim()) {
    uni.showToast({ title: '请输入微信号', icon: 'none' })
    return false
  }
  if (!form.expire_date.trim()) {
    uni.showToast({ title: '请选择到期时间', icon: 'none' })
    return false
  }
  if (!form.flow_photo.trim()) {
    uni.showToast({ title: '请上传主播流水截图', icon: 'none' })
    return false
  }
  // if (!form.operator.trim()) {
  //   uni.showToast({ title: '请输入运营人员', icon: 'none' })
  //   return false
  // }
  return true
}

function handleSubmit() {
  console.log('提交前表单数据:', JSON.stringify(form))
  if (!validateForm()) {
    return
  }

  submitting.value = true
  post('/anchor-resources', {
    platform: form.platform || '',
    nickname: form.nickname || '',
    real_name: form.real_name || '',
    gender: form.gender || '',
    age: form.age || '',
    phone: form.phone || '',
    wechat: form.wechat || '',
    photo: form.photo || '',
    flow_photo: form.flow_photo || '',
    union_name: form.union_name || '',
    current_salary: form.current_salary || '',
    expire_date: form.expire_date || ''
  }).then((res: any) => {
    if (res.code === 200) {
      uni.showToast({ title: res.message || '提交成功', icon: 'success' })
      setTimeout(() => {
        uni.navigateBack()
      }, 1500)
    } else {
      uni.showToast({ title: res.message || '提交失败', icon: 'none' })
    }
  }).catch(() => {
    uni.showToast({ title: '网络错误', icon: 'none' })
  }).finally(() => {
    submitting.value = false
  })
}
</script>

