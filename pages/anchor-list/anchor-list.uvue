		flex-direction: row;
		align-items: center;
		background-color: #F5F5F5;
		border-radius: 40rpx;
		padding: 16rpx 30rpx;
		border: 1rpx solid #E0E0E0;
	}

	.search-icon {
		font-size: 28rpx;
		margin-right: 16rpx;
	}

	.search-input {
		flex: 1;
		font-size: 28rpx;
		color: #333333;
	}

	.search-input::placeholder {
		color: #999999;
	}

	/* 平台信息 */
	.platform-section {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		padding: 20rpx 30rpx;
		background-color: #FFFFFF;
	}

	.platform-info {
		flex-direction: row;
		align-items: center;
	}

	.platform-logo {
		width: 80rpx;
		height: 80rpx;
		border-radius: 16rpx;
		margin-right: 16rpx;
	}

	.platform-name {
		font-size: 30rpx;
		color: #333333;
		font-weight: 500;
	}

	.switch-btn {
		background: linear-gradient(135deg, #F5C76B, #E8B84D);
		padding: 16rpx 32rpx;
		border-radius: 30rpx;
	}

	.switch-text {
		font-size: 26rpx;
		color: #8B6914;
		font-weight: 500;
	}

	/* 标签页 */
	.tabs-section {
		flex-direction: row;
		justify-content: space-around;
		padding: 20rpx 0;
		background-color: #FFFFFF;
		border-bottom: 1rpx solid #EEEEEE;
	}

	.tab-item {
		align-items: center;
		padding: 10rpx 20rpx;
	}

	.tab-text {
		font-size: 28rpx;
		color: #666666;
	}

	.tab-item.active .tab-text {
		color: #333333;
		font-weight: bold;
	}

	.tab-line {
		width: 40rpx;
		height: 4rpx;
		background-color: #F5C76B;
		margin-top: 8rpx;
		border-radius: 2rpx;
	}

	/* 列表区域 */
	.list-section {
		flex: 1;
		padding: 20rpx;
	}

	/* 无数据提示 */
	.empty-tip {
		flex: 1;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		padding: 160rpx 0 80rpx 0;
	}

	.empty-icon {
		font-size: 100rpx;
		margin-bottom: 24rpx;
		opacity: 0.6;
	}

	.empty-text {
		font-size: 28rpx;
		color: #BBBBBB;
	}

	.anchor-card {
		background-color: #FFFFFF;
		border-radius: 16rpx;
		margin-bottom: 20rpx;
		overflow: hidden;
	}

	.card-header {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		padding: 20rpx 24rpx;
		background: linear-gradient(135deg, #F5C76B, #E8B84D);
	}

	.platform-tag {
		font-size: 26rpx;
		color: #FFFFFF;
		font-weight: 500;
	}

	.status-tag {
		font-size: 24rpx;
		color: #FFFFFF;
		padding: 6rpx 16rpx;
		border-radius: 20rpx;
		background-color: rgba(255, 255, 255, 0.3);
	}

	.status-tag.approved {
		color: #4CAF50;
		background-color: rgba(76, 175, 80, 0.2);
	}

	.status-tag.pending {
		color: #FF9800;
		background-color: rgba(255, 152, 0, 0.2);
	}

	.status-tag.rejected {
		color: #F44336;
		background-color: rgba(244, 67, 54, 0.2);
	}

	.card-body {
		padding: 24rpx;
	}

	.anchor-name {
		font-size: 32rpx;
		color: #333333;
		font-weight: bold;
		margin-bottom: 16rpx;
	}

	.info-row {
		flex-direction: row;
		flex-wrap: wrap;
		margin-bottom: 12rpx;
	}

	.info-label {
		font-size: 24rpx;
		color: #999999;
		margin-right: 8rpx;
	}

	.info-label.margin-left {
		margin-left: 30rpx;
	}

	.info-value {
		font-size: 24rpx;
		color: #333333;
	}

	.time-text {
		font-size: 22rpx;
		color: #999999;
	}

	/* 弹窗遮罩 */
	.modal-mask {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.5);
		z-index: 998;
	}

	/* 平台弹窗 */
	.platform-modal {
		position: fixed;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: #FFFFFF;
		border-radius: 24rpx 24rpx 0 0;
		z-index: 999;
		padding-bottom: 40rpx;
	}

	.modal-header {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		padding: 30rpx;
		border-bottom: 1rpx solid #EEEEEE;
	}

	.cancel-btn {
		font-size: 28rpx;
		color: #F5C76B;
	}

	.modal-title {
		font-size: 32rpx;
		color: #333333;
		font-weight: 500;
	}

	.close-btn {
		font-size: 40rpx;
		color: #999999;
		width: 60rpx;
		text-align: center;
	}

	.platform-list {
		max-height: 600rpx;
		padding: 20rpx 0;
	}

	.platform-item {
		flex-direction: row;
		align-items: center;
		padding: 24rpx 30rpx;
		border-bottom: 1rpx solid #F5F5F5;
	}

	.platform-item-logo {
		width: 80rpx;
		height: 80rpx;
		border-radius: 16rpx;
		margin-right: 24rpx;
	}

	.platform-item-name {
		font-size: 30rpx;
		color: #333333;
	}
</style>
